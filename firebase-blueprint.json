{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user account information and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "username": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin", "superadmin"] },
        "sport": { "type": "string" },
        "level": { "type": "string", "enum": ["Junior", "Intermediate", "Senior"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "SecurityNotification": {
      "title": "Security Notification",
      "description": "Logs failed login attempts and suspicious activities.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "type": { "type": "string" },
        "category": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "time": { "type": "string" },
        "status": { "type": "string", "enum": ["unread", "read"] }
      }
    },
    "AuthAttempt": {
      "title": "Auth Attempt",
      "description": "Tracks failed login attempts per email to prevent brute force.",
      "type": "object",
      "properties": {
        "count": { "type": "integer" },
        "lastAttempt": { "type": "string", "format": "date-time" }
      }
    },
    "Fixture": {
      "title": "Fixture",
      "description": "Sports match fixture information.",
      "type": "object",
      "properties": {
        "sport": { "type": "string" },
        "teamA": { "type": "string" },
        "teamB": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "category": { "type": "string" },
        "gender": { "type": "string" },
        "venue": { "type": "string" },
        "status": { "type": "string", "enum": ["scheduled", "completed", "cancelled"] }
      }
    },
    "OverallLeaderboard": {
      "title": "Overall Leaderboard",
      "description": "General ranking of all houses based on total performance.",
      "type": "object",
      "properties": {
        "houseName": { "type": "string" },
        "totalPoints": { "type": "integer" },
        "gold": { "type": "integer" },
        "silver": { "type": "integer" },
        "bronze": { "type": "integer" },
        "rank": { "type": "integer" }
      }
    },
    "SportLeaderboard": {
      "title": "Sport Leaderboard",
      "description": "Ranking for a specific sport.",
      "type": "object",
      "properties": {
        "sport": { "type": "string" },
        "house": { "type": "string" },
        "played": { "type": "integer" },
        "wins": { "type": "integer" },
        "losses": { "type": "integer" },
        "points": { "type": "integer" },
        "rank": { "type": "integer" }
      }
    },
    "MVP": {
      "title": "MVP",
      "description": "Most Valuable Player information.",
      "type": "object",
      "properties": {
        "playerName": { "type": "string" },
        "house": { "type": "string" },
        "sport": { "type": "string" },
        "position": { "type": "string" },
        "achievements": { "type": "string" },
        "points": { "type": "integer" }
      }
    },
    "Match": {
      "title": "Match Result",
      "description": "Latest match results across all sports.",
      "type": "object",
      "properties": {
        "sport": { "type": "string" },
        "houseA": { "type": "string" },
        "houseB": { "type": "string" },
        "scoreA": { "type": "integer" },
        "scoreB": { "type": "integer" },
        "date": { "type": "string" },
        "result": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles collection."
    },
    "/security_notifications/{notificationId}": {
      "schema": "SecurityNotification",
      "description": "Security alerts for super admins."
    },
    "/auth_attempts/{emailKey}": {
      "schema": "AuthAttempt",
      "description": "Brute force protection tracking."
    },
    "/fixtures/{fixtureId}": {
      "schema": "Fixture",
      "description": "Sports match fixtures."
    },
    "/overall_leaderboard/{houseId}": {
      "schema": "OverallLeaderboard",
      "description": "Overall house rankings."
    },
    "/sport_leaderboards/{leaderboardId}": {
      "schema": "SportLeaderboard",
      "description": "Per-sport house rankings."
    },
    "/mvps/{mvpId}": {
      "schema": "MVP",
      "description": "Most Valuable Players list."
    },
    "/matches/{matchId}": {
      "schema": "Match",
      "description": "Completed match results."
    }
  }
}
